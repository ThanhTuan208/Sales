@using CRUD_asp.netMVC.ViewModels.Home
@using System.Globalization
@model HomeViewModel
@{
    ViewData["Title"] = "OrderTracking Page";
    Layout = "_HomeLayout";
}

<div class="tracking-theme">
    <div class="tracking-container">
        <div class="tracking-card">
            <div class="order-info">
                <div class="tracking-header">
                    <h3>Trạng thái đơn hàng</h3>
                    <button>Chi tiết</button>
                </div>
                <h2>Đơn hàng: ...</h2>
                <p>Ngày đặt: ... | Dự kiến: ...</p>
            </div>  

            <div class="tracking-timeline" id="tracking-timeline">
                <div class="tracking-step">
                    <div id="order" class="circle"><i class="fa fa-cart-shopping"></i></div>
                    <span>15 Mar<br />Đặt hàng</span>
                </div>
                <div class="tracking-step">
                    <div id="verify" class="circle"><i class="fa fa-check"></i></div>
                    <span>15 Mar<br />Xác nhận</span>
                </div>
                <div class="tracking-step">
                    <div id="delivery-truck" class="circle"><i class="fa fa-truck"></i></div>
                    <span>15 Mar<br />Gửi hàng</span>
                </div>
                <div class="tracking-step">
                    <div id="delivery-motorcycle" class="circle"><i class="fa fa-motorcycle"></i></div>
                    <span>16 Mar<br />Đang giao hàng</span>
                </div>
                <div class="tracking-step">
                    <div id="order-done" class="circle"><i class="fa fa-box"></i></div>
                    <span>21 Mar<br />Đã giao</span>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="order-detail-theme">
    <div class="order-tabs">
        <ul class="tab-nav">
            <li class="tab-item active" data-tab="pending">Chờ thanh toán</li>
            <li class="tab-item" data-tab="shipping">Đang vận chuyển</li>
            <li class="tab-item" data-tab="success">Giao thành công</li>
            <li class="tab-item" data-tab="failed">Giao thất bại</li>
        </ul>

        <div class="tab-content">
                
            <div class="tab-panel active" data-tab="pending">
                <div id="orderContainer-pending">
                    @await Html.PartialAsync("_OrderPayPartial", Model.PaymentList, new ViewDataDictionary(ViewData)
                    {
                        { "OrderPayList", Model.OrderPayList }
                    })
                </div>
            </div>

            <div class="tab-panel" data-tab="shipping">
                <div id="orderContainer-shipping"></div>
            </div>

            <div class="tab-panel" data-tab="success">
                <div id="orderContainer-success"></div>
            </div>

            <div class="tab-panel" data-tab="failed">
                <div id="orderContainer-failed"></div>
            </div>
        </div>
    </div>

    <div id="loading">
        <div class="spinner"></div>
        <div>Đang tải...</div>
    </div>
</div>

<script src="~/js/jquery-3.7.1.js" asp-append-version="true"></script>
<script src="~/js/order_tracking.js" asp-append-version="true"></script>
@section Scripts {
    <script>
        $(function () {
            // Gọi hàm khởi tạo lazy load với offset ban đầu = số đơn đã load
            initLazyLoad(@Model.PaymentList.Count);
        });

    </script>
}
