@using CRUD_asp.netMVC.ViewModels.Product
@model ProductGeneralViewModel

@{
    ViewData["Title"] = "Tạo sản phẩm mới";
}
<style>
    
    .row[style*="border"] {
        border: 1.5px solid #d3d3d3 !important;
        border-radius: 10px;
        background: #fff;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #7a74ff;
        box-shadow: 0 0 0 0.1rem rgba(122, 116, 255, 0.30);
    }


    .form-control:disabled,
    .form-select:disabled {
        background: #f1f1f1 !important;
        color: #9d9d9d !important;
        border-color: #e0e0e0 !important;
        cursor: not-allowed;
        opacity: .8;
    }
</style>
<h1 class="text-center my-4">Tạo sản phẩm mới</h1>
<hr />

<div class="container">
    <form asp-controller="Admin" asp-action="CreateProduct" enctype="multipart/form-data" method="post" autocomplete="off">
        @* <div asp-validation-summary="All" class="text-danger"></div> *@
        <div class="row">
            <div class="col-lg-6">
                <div class="form-floating mb-3">
                    <input asp-for="Name" id="name" class="form-control" placeholder="Nhập tên sản phẩm" required />
                    <label asp-for="Name" class="form-label">Tên sản phẩm</label>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Picture" id="picture" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" multiple />
                    <label asp-for="Picture" class="form-label">Hình ảnh</label>
                    <span asp-validation-for="Picture" id="displayErrorPicture" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <textarea asp-for="Description" id="description" class="form-control" placeholder="Nhập mô tả" required style="height: 113px"></textarea>
                    <label asp-for="Description" class="form-label">Mô tả</label>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-lg-6">
                        <div class="form-floating mb-3">
                            <select asp-for="CateID" id="cate" class="form-select" asp-items="Model.CategoryList ?? new SelectList(Enumerable.Empty<object>())">
                                <option value="" disabled selected>Chọn danh mục</option>
                            </select>
                            <label asp-for="CateID" class="form-label">Danh mục</label>
                            <span asp-validation-for="CateID" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="form-floating mb-3">
                            <select asp-for="BrandID" id="brand" class="form-select" asp-items="Model.BrandList ?? new SelectList(Enumerable.Empty<object>())">
                                <option value="" disabled selected>Chọn thương hiệu</option>
                            </select>
                            <label asp-for="BrandID" class="form-label">Thương hiệu</label>
                            <span asp-validation-for="BrandID" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-6">
                        <div class="form-floating mb-3">
                            <select asp-for="FeaturedID" id="feature" class="form-select" asp-items="Model.FeaturedList ?? new SelectList(Enumerable.Empty<object>())">
                                <option value="" disabled selected>Chọn hiển thị</option>
                            </select>
                            <label asp-for="FeaturedID" class="form-label">Hiển thị</label>
                            <span asp-validation-for="FeaturedID" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="form-floating mb-3">
                            <select asp-for="GenderID" id="gender" class="form-select" asp-items="Model.GenderList ?? new SelectList(Enumerable.Empty<object>())">
                                <option value="" disabled selected>Chọn giới tính</option>
                            </select>
                            <label asp-for="GenderID" class="form-label">Giới tính</label>
                            <span asp-validation-for="GenderID" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-4">
                        <div class="form-floating mb-3">
                            <input asp-for="NewPrice" type="text" id="newPrice" class="form-control" step="0.01" onforminput="3" required placeholder="Nhập giá mới" />
                            <label asp-for="NewPrice" class="form-label">Giá mới</label>
                            <span asp-validation-for="NewPrice" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="form-floating mb-3">
                            <input asp-for="OldPrice" type="text" id="oldPrice" class="form-control" step="0.01" placeholder="Nhập giá cũ" />
                            <label asp-for="OldPrice" class="form-label">Giá cũ</label>
                            <span asp-validation-for="OldPrice" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="form-floating mb-3">
                            <input asp-for="Quantity" id="product-qty" class="form-control" type="number" required placeholder="Nhập số lượng" disabled />
                            <label asp-for="Quantity" class="form-label">Số lượng</label>
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="form-floating mb-3">
                    <select asp-for="SelectedMaterialID" id="Material" style="height: 150px" class="form-select detail" multiple asp-items="Model.MaterialList ?? new SelectList(Enumerable.Empty<object>())">
                        <option value="" class="text-center" disabled>Chọn chất liệu</option>
                    </select>
                    <label asp-for="SelectedMaterialID" class="form-label">Chất liệu</label>
                    <span asp-validation-for="SelectedMaterialID" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <select asp-for="SelectedColorID" id="Color" style="height: 150px" class="form-select detail" data-val="false" multiple asp-items="Model.ColorList ?? new SelectList(Enumerable.Empty<object>())">
                        <option value="" class="text-center" disabled>Chọn màu sắc</option>
                    </select>
                    <label asp-for="SelectedColorID" class="form-label">Màu sắc</label>
                    @* <span asp-validation-for="SelectedColorID" class="text-danger"></span> *@
                </div>

                <div class="form-floating mb-3">
                    <select asp-for="SelectedSizeID" id="Size" style="height: 150px" class="form-select detail" data-val="false" multiple asp-items="Model.SizeList ?? new SelectList(Enumerable.Empty<object>())" style="height: 150px">
                        <option value="" class="text-center" disabled>Chọn kích cỡ</option>
                    </select>
                    <label asp-for="SelectedSizeID" class="form-label">Kích cỡ</label>
                    @* <span asp-validation-for="SelectedSizeID" class="text-danger"></span> *@
                </div>
            </div>

            <div class="col-lg-3">
                <div class="form-floating mb-3">
                    <select asp-for="SelectedSeasonID" id="Season" style="height: 150px" class="form-select detail" multiple asp-items="Model.SeasonList ?? new SelectList(Enumerable.Empty<object>())" style="height: 150px">
                        <option value="" class="text-center" disabled>Chọn mùa</option>
                    </select>
                    <label asp-for="SelectedSeasonID" class="form-label">Mùa</label>
                    <span asp-validation-for="SelectedSeasonID" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <select asp-for="SelectedStyleID" id="Style" style="height: 150px" class="form-select detail" multiple asp-items="Model.StyleList ?? new SelectList(Enumerable.Empty<object>())" style="height: 150px">
                        <option value="" class="text-center" disabled>Chọn phong cách</option>
                    </select>
                    <label asp-for="SelectedStyleID" class="form-label">Phong cách</label>
                    <span asp-validation-for="SelectedStyleID" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <select asp-for="SelectedTagID" id="Tag" style="height: 150px" class="form-select detail" multiple asp-items="Model.TagList ?? new SelectList(Enumerable.Empty<object>())" style="height: 150px">
                        <option value="" class="text-center" disabled>Chọn thể loại</option>
                    </select>
                    <label asp-for="SelectedTagID" class="form-label">Thể loại</label>
                    <span asp-validation-for="SelectedTagID" class="text-danger"></span>
                </div>
            </div>
        </div>

        @* @if (Model.TempProductQty.Count == 0)
        {
            <p id="displayAlertQty" style="color: red; margin-top: 20px; display: none">Cần cập nhật số lượng sản phẩm ít nhất 1 mục.</p>
        } *@

        <span id="tempProductQty" asp-validation-for="TempProductQty" class="text-danger" style=""></span>

        <div class="row" style="padding: 20px;border: 2px solid black">
            <div class="display-detail d-flex justify-content-between align-items-center">
                <h3>Thuộc tính</h3>
                <a href="#" id="update-qty">Cập nhật số lượng</a>
            </div>
        </div>
        <div class="d-flex justify-content-center align-items-center">
            <input class="countQty" type="hidden" value="@Model.TempProductQty.Count" />
            <button type="submit" id="btnAdminProduct" class="btn btn-outline-secondary my-3" style="width: 20%">Tạo</button>
        </div>
    </form>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function(){
          window.history.replaceState({}, document.title, window.location.pathname);
        });
    </script>
}

