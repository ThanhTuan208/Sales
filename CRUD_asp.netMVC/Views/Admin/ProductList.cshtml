@using CRUD_asp.netMVC.Models.Product;
@using System.Globalization
@model PaginatedList<Products>

@{
    ViewData["Title"] = "Sản phẩm";
}

<style>

    table th, table td {
        text-align: center;
        vertical-align: middle;
    }

    .pagination .btn {
        transition: 0.3s;
        margin-right: 0px;
    }

</style>
