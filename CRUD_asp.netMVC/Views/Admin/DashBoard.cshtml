@using CRUD_asp.netMVC.ViewModels.Admin;
@using System.Globalization
@model DashBoardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="tab-pane fade show active" id="overview" role="tabpanel" aria-labelledby="overview">
    <div class="row mb-4">
        @foreach (var info in Model.DashBoards)
        {
            <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4">
                <div class="card">
                    <div class="card-body p-3">
                        <div class="row">
                            <div class="col-8">
                                <div class="numbers">
                                    <p class="text-sm mb-0 text-uppercase font-weight-bold">@info.Title</p>
                                    <h6 id="@info.IdValue" class="font-weight-bolder" style="font-size: 20px">
                                        <strong>@info.Value</strong>
                                    </h6>
                                    <p class="mb-0">
                                        <span id="@info.IdChangetext" class="@info.ChangeClass text-sm font-weight-bolder">@info.ChangeText</span>
                                    </p>
                                </div>
                            </div>
                            <div class="col-4 text-end">
                                <div class="icon icon-shape @info.Gradient text-center rounded-circle">
                                    <i class="@info.Icon text-lg opacity-10" aria-hidden="true"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row">
        <div class="col-lg-8 d-flex flex-column">
            <div class="row flex-grow">
                <div class="col-12 grid-margin stretch-card">
                    <div class="card card-rounded">
                        <div class="card-body">
                            <div class="d-sm-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="card-title card-title-dash">
                                        Tổng quan thị trường
                                    </h4>
                                    <p class="card-subtitle card-subtitle-dash">
                                        Theo dõi doanh thu và xu hướng bán hàng
                                    </p>
                                </div>
                                <div>
                                    <div class="dropdown">
                                        <button class="btn btn-light dropdown-toggle toggle-dark btn-lg mb-0 me-0"
                                                type="button"
                                                id="dropdownMenuButton2"
                                                data-bs-toggle="dropdown"
                                                aria-haspopup="true"
                                                aria-expanded="false">
                                            Tháng này
                                        </button>
                                        <div class="dropdown-menu" aria-labelledby="dropdownMenuButton2">
                                            <a class="dropdown-item" href="#">Tuần này</a>
                                            <a class="dropdown-item" href="#">Tháng này</a>
                                            <a class="dropdown-item" href="#">Năm này</a>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-sm-flex align-items-center mt-1 justify-content-between">
                                <div class="d-sm-flex align-items-center mt-4 justify-content-between">
                                    <h2 class="me-2 fw-bold">36.253.100 ₫</h2>
                                    <h4 class="me-2">VND</h4>
                                    <h4 class="text-success">(+1.37%)</h4>
                                </div>
                                <div class="me-3">
                                    <div id="marketingOverview-legend"></div>
                                </div>
                            </div>

                            <div class="chartjs-bar-wrapper mt-3">
                                <canvas id="marketingOverview"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pending Requests -->
            <div class="row flex-grow">
                <div class="col-12 grid-margin stretch-card">
                    <div class="card card-rounded">
                        <div class="card-body">
                            <div class="d-sm-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="card-title card-title-dash">
                                        Yêu cầu đang chờ xử lý
                                    </h4>
                                    <p class="card-subtitle card-subtitle-dash">
                                        Bạn có hơn 50 yêu cầu mới cần xử lý
                                    </p>
                                </div>
                                <div>
                                    <button class="btn btn-primary btn-lg text-white mb-0 me-0" type="button">
                                        <i class="mdi mdi-account-plus"></i> Thêm thành viên mới
                                    </button>
                                </div>
                            </div>

                            <div class="table-responsive mt-1">
                                <table class="table select-table">
                                    <thead>
                                        <tr>
                                            <th>
                                                <div class="form-check form-check-flat mt-0">
                                                    <label class="form-check-label">
                                                        <input type="checkbox" class="form-check-input" aria-checked="false" id="check-all" />
                                                        <i class="input-helper"></i>
                                                    </label>
                                                </div>
                                            </th>
                                            <th>Khách hàng</th>
                                            <th>Công ty</th>
                                            <th>Tiến độ</th>
                                            <th>Trạng thái</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>
                                                <div class="form-check form-check-flat mt-0">
                                                    <label class="form-check-label">
                                                        <input type="checkbox" class="form-check-input" aria-checked="false" />
                                                        <i class="input-helper"></i>
                                                    </label>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex">
                                                    <img src="@Url.Content("/images/avatar/userA.jpg")" alt="" />
                                                    <div>
                                                        <h6>Phan Anh Ngọc</h6>
                                                        <p>Quản trị viên chính</p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <h6>Công ty VCB</h6>
                                                <p>Loại hình công ty</p>
                                            </td>
                                            <td>
                                                <div>
                                                    <div class="d-flex justify-content-between align-items-center mb-1 max-width-progress-wrap">
                                                        <p class="text-success">79%</p>
                                                        <p>85/162</p>
                                                    </div>
                                                    <div class="progress progress-md">
                                                        <div class="progress-bar bg-success" role="progressbar" style="width: 85%" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="badge badge-opacity-warning">Đang thực hiện</div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <div class="form-check form-check-flat mt-0">
                                                    <label class="form-check-label">
                                                        <input type="checkbox" class="form-check-input" aria-checked="false" />
                                                        <i class="input-helper"></i>
                                                    </label>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex">
                                                    <img src="@Url.Content("/images/avatar/userB.png")" alt="" />
                                                    <div>
                                                        <h6>Tăng Thị Diệu Hương</h6>
                                                        <p>Quản trị viên chính</p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <h6>Công ty VCB</h6>
                                                <p>Loại hình công ty</p>
                                            </td>
                                            <td>
                                                <div>
                                                    <div class="d-flex justify-content-between align-items-center mb-1 max-width-progress-wrap">
                                                        <p class="text-success">79%</p>
                                                        <p>85/162</p>
                                                    </div>
                                                    <div class="progress progress-md">
                                                        <div class="progress-bar bg-success" role="progressbar" style="width: 65%" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="badge badge-opacity-warning">Đang thực hiện</div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột bên phải -->
        <div class="col-lg-4 d-flex flex-column">

            <!-- Todo List -->
            <div class="row flex-grow">
                <div class="col-12 grid-margin stretch-card">
                    <div class="card card-rounded">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-12">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h4 class="card-title card-title-dash">Danh sách công việc</h4>
                                        <div class="add-items d-flex mb-0">
                                            <button class="add btn btn-icons btn-rounded btn-primary todo-list-add-btn text-white me-0 pl-12p">
                                                <i class="mdi mdi-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="list-wrapper">
                                        <ul class="todo-list todo-list-rounded">
                                            <li class="d-block">
                                                <div class="form-check w-100">
                                                    <label class="form-check-label">
                                                        <input class="checkbox" type="checkbox" />
                                                        Kiểm tra sản phẩm tồn kho
                                                        <i class="input-helper rounded"></i>
                                                    </label>
                                                    <div class="d-flex mt-2">
                                                        <div class="ps-4 text-small me-3">24 Tháng 6, 2026</div>
                                                        <div class="badge badge-opacity-warning me-3">Hạn mai</div>
                                                        <i class="mdi mdi-flag ms-2 flag-color"></i>
                                                    </div>
                                                </div>
                                            </li>
                                            <li class="d-block">
                                                <div class="form-check w-100">
                                                    <label class="form-check-label">
                                                        <input class="checkbox" type="checkbox" />
                                                        Tổng hợp báo cáo doanh thu tháng trước
                                                        <i class="input-helper rounded"></i>
                                                    </label>
                                                    <div class="d-flex mt-2">
                                                        <div class="ps-4 text-small me-3">24 Tháng 6, 2026</div>
                                                        <div class="badge badge-opacity-warning me-3">Hạn mai</div>
                                                        <i class="mdi mdi-flag ms-2 flag-color"></i>
                                                    </div>
                                                </div>
                                            </li>
                                            <!-- Thêm các mục todo khác tương tự -->
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Type By Amount -->
            <div class="row flex-grow">
                <div class="col-12 grid-margin stretch-card">
                    <div class="card card-rounded">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-12">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h4 class="card-title card-title-dash">Phân loại theo số lượng</h4>
                                    </div>
                                    <div>
                                        <canvas class="my-auto" id="doughnutChart"></canvas>
                                    </div>
                                    <div id="doughnutChart-legend" class="mt-5 text-center"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Leave Report -->
            <div class="row flex-grow">
                <div class="col-12 grid-margin stretch-card">
                    <div class="card card-rounded">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-12">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div>
                                            <h4 class="card-title card-title-dash">Báo cáo nghỉ phép</h4>
                                        </div>
                                        <div>
                                            <div class="dropdown">
                                                <button class="btn btn-light dropdown-toggle toggle-dark btn-lg mb-0 me-0"
                                                        type="button"
                                                        id="dropdownMenuButton3"
                                                        data-bs-toggle="dropdown"
                                                        aria-haspopup="true"
                                                        aria-expanded="false">
                                                    Theo tháng
                                                </button>
                                                <div class="dropdown-menu" aria-labelledby="dropdownMenuButton3">
                                                    <h6 class="dropdown-header">Theo tuần</h6>
                                                    <a class="dropdown-item" href="#">Theo năm</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <canvas id="leaveReport"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>