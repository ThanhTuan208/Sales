@using CRUD_asp.netMVC.ViewModels.Home
@using System.Globalization
@model SurplusMoneyViewModel
@{
    ViewData["Title"] = "Home Page";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" asp-append-version="true" />

<div class="transaction-list" id="transactionList">
    <div class="profile-main">
        <div class="container surplus">
            <div class="header">
                <h2 class="mb-0 fw-semibold">Túi tiền của tôi</h2>
                <button class="theme-toggle" id="themeToggle">
                    <i class="bi bi-moon-stars-fill"></i>
                </button>
            </div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="balance-card mb-4">
                        <h5 class="fw-light text-muted mb-3">Số tiền dư hiện tại</h5>
                        <div class="balance-amount">
                            @string.Format(new CultureInfo("vi-VN"), "{0:N0}", Model.ExcessMoney) <span class="fs-4">VND</span>
                        </div>
                        <p class="mt-4 mb-0 text-muted small">
                            Cập nhật: @Model.UpdateAt
                        </p>
                    </div>

                    <div class="stats-grid">
                        <div class="stats-item">
                            <i class="bi bi-arrow-up-circle-fill stats-icon"></i>
                            <h6 class="text-muted mb-1">Tiền vào tháng này</h6>
                            <h4 class="fw-bold text-success">+@string.Format(new CultureInfo("vi-VN"), "{0:C0}", Model.TotalAmountInMonth)</h4>
                        </div>
                        <div class="stats-item">
                            <i class="bi bi-arrow-down-circle-fill stats-icon"></i>
                            <h6 class="text-muted mb-1">Đã chi</h6>
                            <h4 class="fw-bold text-danger">-@string.Format(new CultureInfo("vi-VN"), "{0:C0}", Model.PaidMoney)</h4>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <button class="withdraw-btn">Yêu cầu hoàn tiền</button>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card rounded-4 h-100"
                         style="background: var(--card-bg);box-shadow: var(--shadow);border: none;">
                        <div class="card-header-detail bg-transparent border-bottom py-3" style="text-align: center">
                            <h5 class="mb-0">
                                <strong>Giao dịch gần đây</strong>
                            </h5>
                        </div>
                        <div class="card-body timeline m-2">
                            @foreach (var item in Model.MoneyFlowLogs.Take(4))
                            {
                                <div class="timeline-item transaction-item d-flex justify-content-between align-items-center"
                                     data-id="@item.Id"
                                     data-type="@item.Type"
                                     data-amount="@item.Amount"
                                     data-balance="@(item.BalanceSnapshot?.ToString("N0", CultureInfo.InvariantCulture) ?? "")"
                                     data-description="@item.Description"
                                     data-date="@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                     data-related-id="@item.RelatedId"
                                     data-user-id="@item.UserId">
                                    <div>
                                        <h5 class="mb-1"> <strong>Mã đơn:</strong> </h5>
                                        <h6 class="mb-1">@item.Description</h6>
                                        <small class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                    <span class="item-amount fw-bold">
                                        @string.Format(new CultureInfo("vi-VN"), "{0:C0}", item.Amount)
                                    </span>
                                </div>
                            }
                        </div>

                        <div class="card-footer bg-transparent text-center py-3">
                            <a href="#" class="view-all-link">Xem tất cả giao dịch</a>
                        </div>

                        <div class="modal-overlay">
                            <div class="modal-box">
                                <span class="close-btn"><i class="bi bi-x-lg"></i></span>

                                <div class="modal-header-modal">
                                    <h2 id="history-modal-title">Lịch Sử Giao Dịch</h2>
                                    <div class="header-line"></div>
                                </div>

                                <div class="payment-list custom-scrollbar">
                                    @foreach (var log in Model.MoneyFlowLogs)
                                    {
                                        <div class="payment-item transaction-item"
                                             data-id="@log.Id"
                                             data-type="@log.Type"
                                             data-amount="@log.Amount"
                                             data-balance="@(log.BalanceSnapshot?.ToString("N0", CultureInfo.InvariantCulture) ?? "")"
                                             data-description="@log.Description"
                                             data-date="@log.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                             data-related-id="@log.RelatedId"
                                             data-user-id="@log.UserId">

                                            <div class="icon-box"><i class="bi bi-cart-check"></i></div>
                                            <div class="item-info">
                                                <p class="title">Mua sắm thiết bị điện tử</p>
                                                <p class="date">@log.CreatedAt.ToString("dd/MM/yyyy - HH:mm")</p>
                                            </div>
                                            <div class="item-amount">@string.Format(new CultureInfo("vi-VN"), "{0:C0}", log.Amount)</div>
                                        </div>
                                    }

                                </div>

                                <div class="modal-footer">
                                    <div class="total-box">
                                        <span>Tổng chi tiêu (Tháng 12)</span>
                                        <span style="color: #e74c3c;">- 16,570,000đ</span>
                                    </div>
                                    <button class="btn-confirm">Xuất Báo Cáo PDF</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
